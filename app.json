{
  "expo": {
    "name": "Kasa",
    "slug": "kasa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/kasa-logo.png",
    "scheme": "kasa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/kasa-logo.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.joenash156.kasa"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/kasa-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/kasa-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6762fd38-885e-4ff3-b583-bfcb646205e4"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6762fd38-885e-4ff3-b583-bfcb646205e4"
    }
  }
}
