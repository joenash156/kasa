# Kasa Caller Mobile App Environment Configuration

# ============================================================================
# API Configuration
# ============================================================================

# Base URL for the Kasa Caller API (without trailing slash)
# Example: https://api.kasa.com/caller/api
# For local development: http://localhost:3000/caller/api
EXPO_PUBLIC_API_URL=https://<your-server>/caller/api

# API Key issued by Kasa Admin Portal
# Required header: X-API-Key
# Get this from the Kasa admin dashboard
EXPO_PUBLIC_API_KEY=your-admin-issued-api-key-here

# ============================================================================
# App Configuration
# ============================================================================

# App environment: development or production
EXPO_PUBLIC_APP_ENV=development

# Enable or disable API request/response logging in dev
EXPO_PUBLIC_LOG_API=true

# ============================================================================
# Feature Flags (Optional)
# ============================================================================

# Enable offline mode support (future feature)
EXPO_PUBLIC_OFFLINE_MODE=false

# Enable analytics tracking (future feature)
EXPO_PUBLIC_ANALYTICS=false
